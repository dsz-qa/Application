<UserControl x:Class="Finly.Pages.GoalsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Finly.Pages"
             mc:Ignorable="d"
             Background="{DynamicResource App.Background}"
             Foreground="{DynamicResource App.Foreground}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">

    <UserControl.Resources>

        <!-- Style wspólne -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface.Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Surface.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,12,16,0"/>
        </Style>

        <Style x:Key="SelectableGoalCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brand.Orange}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="BorderBrush" Value="{DynamicResource Brand.Blue}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="0,16,16,0"/>
        </Style>

        <Style x:Key="CardHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <Style x:Key="KpiValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource App.Foreground}"/>
        </Style>

        <!-- ===== KARTA CELU ===== -->
        <DataTemplate DataType="{x:Type local:GoalVm}">
            <Border Style="{StaticResource SelectableGoalCard}"
                    Width="340"
                    MouseLeftButtonUp="GoalCard_MouseLeftButtonUp">
                <StackPanel>

                    <!-- Nagłówek -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6" Background="Transparent">
                        <Rectangle Width="24"
                                   Height="24"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Top"
                                   Fill="{DynamicResource Brand.Orange}">
                            <Rectangle.OpacityMask>
                                <ImageBrush Stretch="Uniform" ImageSource="/Assets/Icons/cele.png"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>

                        <TextBlock FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource App.Foreground}"
                                   TextWrapping="Wrap"
                                   MaxWidth="280"
                                   VerticalAlignment="Center">
                            <Run Text="Cel: "/>
                            <Run Text="{Binding GoalTitle, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="Docelowa kwota"
                               FontWeight="Bold"
                               Foreground="{DynamicResource App.Foreground}"
                               Opacity="0.9"/>
                    <TextBlock Text="{Binding TargetAmount, StringFormat={}{0:N2} zł}"
                               Margin="0,2,0,6"
                               Foreground="{DynamicResource App.Foreground}"/>

                    <TextBlock Text="Już odłożone"
                               FontWeight="Bold"
                               Foreground="{DynamicResource App.Foreground}"
                               Opacity="0.9"/>
                    <TextBlock Text="{Binding CurrentAmount, StringFormat={}{0:N2} zł}"
                               Margin="0,2,0,6"
                               Foreground="{DynamicResource App.Foreground}"/>

                    <TextBlock Text="Do celu pozostało"
                               FontWeight="Bold"
                               Foreground="{DynamicResource App.Foreground}"
                               Opacity="0.9"/>
                    <TextBlock Text="{Binding Remaining, StringFormat={}{0:N2} zł}"
                               Margin="0,2,0,6"
                               Foreground="{DynamicResource App.Foreground}"/>

                    <TextBlock Text="Zrealizowano"
                               FontWeight="Bold"
                               Foreground="{DynamicResource App.Foreground}"
                               Opacity="0.9"/>
                    <StackPanel Margin="0,2,0,6">
                        <TextBlock Text="{Binding CompletionPercent, StringFormat={}{0:N0}%}"
                                   Foreground="{DynamicResource App.Foreground}"/>
                        <ProgressBar Height="6"
                                     Margin="0,4,0,0"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding CompletionPercent, Mode=OneWay}"/>
                    </StackPanel>

                    <TextBlock Text="Miesięcznie musisz odkładać"
                               FontWeight="Bold"
                               Foreground="{DynamicResource App.Foreground}"
                               Opacity="0.9"/>
                    <TextBlock Text="{Binding MonthlyNeeded, StringFormat={}{0:N2} zł}"
                               Margin="0,2,0,6"
                               Foreground="{DynamicResource App.Foreground}"/>

                    <TextBlock Text="Termin osiągnięcia celu"
                               FontWeight="Bold"
                               Foreground="{DynamicResource App.Foreground}"
                               Opacity="0.9"/>
                    <TextBlock Margin="0,2,0,6"
                               Foreground="{DynamicResource App.Foreground}"
                               Text="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}, TargetNullValue=Brak terminu}"/>

                    <TextBlock Text="Opis"
                               FontWeight="Bold"
                               Foreground="{DynamicResource App.Foreground}"
                               Opacity="0.9"/>
                    <TextBlock Text="{Binding Description}"
                               Margin="0,2,0,4"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource App.Foreground}"/>

                    <!-- Przyciski -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">
                        <Button Click="EditGoal_Click"
                                Style="{StaticResource EditIconButton}"
                                Margin="0,0,8,0"/>
                        <Button Click="DeleteGoal_Click"
                                Style="{StaticResource DeleteIconButton}"/>
                    </StackPanel>

                    <!-- Panel potwierdzenia usunięcia -->
                    <StackPanel x:Name="GoalDeleteConfirmPanel"
                                Orientation="Vertical"
                                Margin="0,6,0,0"
                                Visibility="Collapsed">
                        <TextBlock Text="Czy na pewno chcesz usunąć ten cel?"
                                   FontSize="12"
                                   Foreground="{DynamicResource App.Foreground}"
                                   Margin="0,0,0,4"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Tak"
                                    Margin="0,0,8,0"
                                    Padding="8,3"
                                    MinWidth="60"
                                    Click="DeleteGoalConfirm_Click"/>
                            <Button Content="Nie"
                                    Padding="8,3"
                                    MinWidth="60"
                                    Click="DeleteGoalCancel_Click"/>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ===== KAFEL „DODAJ CEL” ===== -->
        <DataTemplate DataType="{x:Type local:AddGoalTile}">
            <Border Style="{StaticResource Card}"
                    Width="260"
                    Cursor="Hand"
                    MouseLeftButtonUp="AddGoalCard_Click">
                <Grid>
                    <Border Margin="10"
                            BorderThickness="1"
                            CornerRadius="8"
                            BorderBrush="{DynamicResource Surface.Border}"/>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="0,16,0,16">
                        <TextBlock Text="+"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource App.Foreground}"/>
                        <TextBlock Text="Dodaj cel"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource App.Foreground}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <!-- CAŁA STRONA -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,24,24,60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- KPI -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource AccentCard}">
                    <StackPanel>
                        <TextBlock Text="Cele – łączna kwota do uzbierania"
                                   Style="{StaticResource CardHeader}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TotalGoalsAmountText"
                                   Style="{StaticResource KpiValueStyle}"
                                   FontSize="24"
                                   Text="0,00 zł"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource AccentCard}">
                    <StackPanel>
                        <TextBlock Text="Już odłożone na cele"
                                   Style="{StaticResource CardHeader}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TotalGoalsSavedText"
                                   Style="{StaticResource KpiValueStyle}"
                                   FontSize="24"
                                   Text="0,00 zł"/>
                    </StackPanel>
                </Border>

                <!-- ostatni kafelek bez prawego marginesu AccentCard -->
                <Border Grid.Column="2" Style="{StaticResource AccentCard}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Łącznie miesięcznie trzeba odkładać"
                                   Style="{StaticResource CardHeader}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TotalMonthlyNeededText"
                                   Style="{StaticResource KpiValueStyle}"
                                   FontSize="24"
                                   Text="0,00 zł"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- LISTA CELÓW -->
            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <Separator Height="1"
                           Background="{DynamicResource Surface.Border}"
                           Opacity="0.8"
                           Margin="0,0,0,8"/>

                <!-- Nagłówek sekcji -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                    <Rectangle Width="30"
                               Height="30"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Fill="{DynamicResource Brand.Orange}">
                        <Rectangle.OpacityMask>
                            <ImageBrush Stretch="Uniform" ImageSource="/Assets/Icons/cele.png"/>
                        </Rectangle.OpacityMask>
                    </Rectangle>

                    <TextBlock Text="Cele"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource App.Foreground}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <ListBox x:Name="GoalsList"
                         Margin="0,8,0,0"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         AllowDrop="True"
                         PreviewMouseLeftButtonDown="GoalsList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="GoalsList_PreviewMouseMove"
                         Drop="GoalsList_Drop"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Top"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="IsHitTestVisible" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- klucz: IsItemsHost + brak nieskończonej szerokości => Wrap działa -->
                            <WrapPanel Orientation="Horizontal"
                                       HorizontalAlignment="Left"
                                       IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                </ListBox>
            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>